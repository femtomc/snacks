  "permissions": {
    "deny": ["Agent(general-purpose)"]
  },
  "env": {
    "CLAUDE_CODE_MAX_OUTPUT_TOKENS": "128000",
    "CLAUDE_CODE_AUTOCOMPACT_PCT_OVERRIDE": "98"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "statusLine": {
    "type": "command",

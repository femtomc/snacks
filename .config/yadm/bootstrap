#!/bin/bash
set -euo pipefail

# snacks bootstrap — run after `yadm clone` on a fresh machine

echo "=== snacks bootstrap ==="

# ---- helpers ----
have() { command -v "$1" &>/dev/null; }

OS="$(uname -s)"    # Linux or Darwin
ARCH="$(uname -m)"  # x86_64 or arm64

# ---- system packages ----
if [ "$OS" = "Linux" ] && have apt-get; then
    echo "--- apt packages ---"
    sudo apt-get update -qq
    sudo apt-get install -y -qq \
        git curl wget build-essential cmake jq \
        zsh tmux kitty \
        python3 python3-venv \
        fontconfig unzip
elif [ "$OS" = "Darwin" ]; then
    if ! have brew; then
        echo "--- homebrew ---"
        /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
        eval "$(/opt/homebrew/bin/brew shellenv 2>/dev/null || /usr/local/bin/brew shellenv)"
    fi
    echo "--- brew packages ---"
    brew install git curl wget cmake jq \
        zsh tmux kitty \
        python3 \
        fontconfig unzip
fi

# ---- GitHub CLI ----
if ! have gh; then
    echo "--- gh (GitHub CLI) ---"
    if [ "$OS" = "Darwin" ]; then
        brew install gh
    elif have apt-get; then
        (type -p wget >/dev/null || sudo apt-get install wget -y) \
            && sudo mkdir -p -m 755 /etc/apt/keyrings \
            && out=$(mktemp) && wget -qO "$out" https://cli.github.com/packages/githubcli-archive-keyring.gpg \
            && sudo tee /etc/apt/keyrings/githubcli-archive-keyring.gpg < "$out" >/dev/null \
            && sudo chmod go+r /etc/apt/keyrings/githubcli-archive-keyring.gpg \
            && echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" | sudo tee /etc/apt/sources.list.d/github-cli.list >/dev/null \
            && sudo apt-get update -qq && sudo apt-get install -y -qq gh
    fi
fi

# ---- Rust toolchain ----
if ! have rustup; then
    echo "--- rustup + cargo ---"
    curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y
    source "$HOME/.cargo/env"
fi

# ---- Cargo CLI tools ----
echo "--- cargo tools ---"
cargo_tools=(
    eza        # ls replacement
    bat        # cat replacement
    git-delta  # git pager
    fd-find    # find replacement
    ripgrep    # grep replacement
    zoxide     # cd replacement
    bob-nvim   # nvim version manager
)
for tool in "${cargo_tools[@]}"; do
    case "$tool" in
        git-delta) bin="delta" ;;
        fd-find)   bin="fd" ;;
        ripgrep)   bin="rg" ;;
        bob-nvim)  bin="bob" ;;
        *)         bin="$tool" ;;
    esac
    if ! have "$bin"; then
        echo "  cargo install $tool"
        cargo install "$tool"
    fi
done

# ---- Neovim (via bob) ----
if ! have nvim; then
    echo "--- nvim (via bob) ---"
    bob use stable
fi

# ---- fzf (git install — gives keybindings + shell integration) ----
if [ ! -d "$HOME/.fzf" ]; then
    echo "--- fzf ---"
    git clone --depth 1 https://github.com/junegunn/fzf.git "$HOME/.fzf"
    "$HOME/.fzf/install" --all --no-bash --no-fish
fi

# ---- Starship prompt ----
if ! have starship; then
    echo "--- starship ---"
    curl -sS https://starship.rs/install.sh | sh -s -- -y
fi

# ---- elan (Lean 4 version manager) ----
if ! have elan; then
    echo "--- elan ---"
    curl https://elan-init.github.io/elan/elan-init.sh -sSf | sh -s -- -y --default-toolchain stable
fi

# ---- mise (version manager: zig, elixir, node, npx) ----
if ! have mise; then
    echo "--- mise ---"
    curl https://mise.run | sh
fi
if have mise; then
    echo "--- mise install ---"
    mise install
fi

# ---- uv (Python tooling) ----
if ! have uv; then
    echo "--- uv ---"
    curl -LsSf https://astral.sh/uv/install.sh | sh
fi

# ---- bun ----
if ! have bun; then
    echo "--- bun ---"
    curl -fsSL https://bun.sh/install | bash
fi

# ---- flyctl (Fly.io) ----
if ! have flyctl; then
    echo "--- flyctl ---"
    curl -L https://fly.io/install.sh | sh
fi

# ---- lazygit ----
if ! have lazygit; then
    echo "--- lazygit ---"
    LAZYGIT_VERSION=$(curl -s "https://api.github.com/repos/jesseduffield/lazygit/releases/latest" | jq -r '.tag_name' | sed 's/^v//')
    if [ "$OS" = "Darwin" ]; then
        LG_PLATFORM="Darwin"
        [ "$ARCH" = "arm64" ] && LG_ARCH="arm64" || LG_ARCH="x86_64"
    else
        LG_PLATFORM="Linux"
        LG_ARCH="x86_64"
    fi
    curl -Lo /tmp/lazygit.tar.gz "https://github.com/jesseduffield/lazygit/releases/download/v${LAZYGIT_VERSION}/lazygit_${LAZYGIT_VERSION}_${LG_PLATFORM}_${LG_ARCH}.tar.gz"
    tar xf /tmp/lazygit.tar.gz -C /tmp lazygit
    sudo install /tmp/lazygit /usr/local/bin/lazygit
    rm /tmp/lazygit /tmp/lazygit.tar.gz
fi

# ---- act (GitHub Actions local runner) ----
if ! have act; then
    echo "--- act ---"
    mkdir -p "$HOME/act"
    curl -s https://raw.githubusercontent.com/nektos/act/master/install.sh | bash -s -- -b "$HOME/act"
fi

# ---- Oh My Zsh ----
if [ ! -d "$HOME/.oh-my-zsh" ]; then
    echo "--- oh-my-zsh ---"
    sh -c "$(curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh)" "" --unattended
fi

# zsh plugins
ZSH_CUSTOM="${ZSH_CUSTOM:-$HOME/.oh-my-zsh/custom}"
[ -d "$ZSH_CUSTOM/plugins/zsh-autosuggestions" ] || \
    git clone https://github.com/zsh-autosuggestions/zsh-autosuggestions "$ZSH_CUSTOM/plugins/zsh-autosuggestions"
[ -d "$ZSH_CUSTOM/plugins/zsh-syntax-highlighting" ] || \
    git clone https://github.com/zsh-users/zsh-syntax-highlighting "$ZSH_CUSTOM/plugins/zsh-syntax-highlighting"

# ---- TPM (tmux plugin manager) ----
if [ ! -d "$HOME/.tmux/plugins/tpm" ]; then
    echo "--- tpm ---"
    git clone https://github.com/tmux-plugins/tpm "$HOME/.tmux/plugins/tpm"
fi

# ---- bellman (agent work-graph orchestrator) ----
if ! have bellman; then
    echo "--- bellman ---"
    uv tool install "bellman @ git+https://github.com/evil-mind-evil-sword/workshop.git#subdirectory=core/tiny/tools/bellman"
fi

# ---- smg (semantic graph for architecture) ----
if ! have smg; then
    echo "--- smg ---"
    uv tool install "smg[scan] @ git+https://github.com/femtomc/smg.git"
fi

# ---- Claude Code ----
if ! have claude; then
    echo "--- claude code ---"
    curl -fsSL https://claude.ai/install.sh | sh
fi

# ---- Codex (OpenAI) ----
if ! have codex; then
    echo "--- codex ---"
    npm install -g @openai/codex
fi

# ---- keyd (Mac-style keybindings, Linux only) ----
if [ "$OS" = "Linux" ]; then
    if ! have keyd; then
        echo "--- keyd ---"
        if have apt-get; then
            sudo apt-get install -y -qq keyd 2>/dev/null || {
                # Build from source if not in repos
                tmpdir=$(mktemp -d)
                git clone https://github.com/rvaiya/keyd "$tmpdir/keyd"
                cd "$tmpdir/keyd" && make && sudo make install
                cd "$HOME" && rm -rf "$tmpdir"
            }
        fi
    fi
    if [ -f "$HOME/.config/keyd/default.conf" ]; then
        echo "--- keyd config ---"
        sudo mkdir -p /etc/keyd
        sudo cp "$HOME/.config/keyd/default.conf" /etc/keyd/default.conf
        sudo systemctl enable keyd && sudo systemctl restart keyd
    fi
fi

# ---- Skill symlinks ----
echo "--- skill symlinks ---"
for tool_dir in "$HOME/.claude/skills" "$HOME/.codex/skills"; do
    mkdir -p "$tool_dir"
    for skill in "$HOME/.config/skills"/*/; do
        name=$(basename "$skill")
        target="$tool_dir/$name"
        if [ ! -e "$target" ]; then
            ln -s "$HOME/.config/skills/$name" "$target"
            echo "  linked $name → $tool_dir"
        fi
    done
done

# ---- Pre-commit hook ----
if have yadm && [ -f "$HOME/.config/yadm/hooks/pre-commit" ]; then
    echo "--- pre-commit hook ---"
    HOOKS_DIR="$HOME/.local/share/yadm/repo.git/hooks"
    cp "$HOME/.config/yadm/hooks/pre-commit" "$HOOKS_DIR/pre-commit"
    chmod +x "$HOOKS_DIR/pre-commit"
fi

# ---- Default shell ----
if [ "$SHELL" != "$(which zsh)" ]; then
    echo "--- default shell → zsh ---"
    chsh -s "$(which zsh)" || echo "  (run manually: chsh -s \$(which zsh))"
fi

# ---- Decrypt secrets ----
if have yadm && [ -f "$HOME/.config/yadm/encrypt" ]; then
    echo "--- secrets ---"
    yadm decrypt || echo "  (run manually: yadm decrypt)"
fi

echo
echo "=== bootstrap complete ==="
echo "Restart your shell or run: exec zsh"

#!/bin/bash
set -euo pipefail

# snacks bootstrap — run after `yadm clone` on a fresh machine

echo "=== snacks bootstrap ==="

# ---- helpers ----
have() { command -v "$1" &>/dev/null; }
need() { have "$1" || return 0; }  # guard for sections that require a prior install

# ---- system packages (apt) ----
if have apt-get; then
    echo "--- apt packages ---"
    sudo apt-get update -qq
    sudo apt-get install -y -qq \
        git curl wget build-essential cmake jq \
        zsh tmux kitty \
        python3 python3-venv \
        fontconfig unzip
fi

# ---- GitHub CLI ----
if ! have gh; then
    echo "--- gh (GitHub CLI) ---"
    (type -p wget >/dev/null || sudo apt-get install wget -y) \
        && sudo mkdir -p -m 755 /etc/apt/keyrings \
        && out=$(mktemp) && wget -qO "$out" https://cli.github.com/packages/githubcli-archive-keyring.gpg \
        && cat "$out" | sudo tee /etc/apt/keyrings/githubcli-archive-keyring.gpg >/dev/null \
        && sudo chmod go+r /etc/apt/keyrings/githubcli-archive-keyring.gpg \
        && echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" | sudo tee /etc/apt/sources.list.d/github-cli.list >/dev/null \
        && sudo apt-get update -qq && sudo apt-get install -y -qq gh
fi

# ---- Rust toolchain ----
if ! have rustup; then
    echo "--- rustup + cargo ---"
    curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y
    source "$HOME/.cargo/env"
fi

# ---- Cargo CLI tools ----
echo "--- cargo tools ---"
cargo_tools=(
    eza        # ls replacement
    bat        # cat replacement
    git-delta  # git pager
    fd-find    # find replacement
    ripgrep    # grep replacement
    zoxide     # cd replacement
    bob-nvim   # nvim version manager
)
for tool in "${cargo_tools[@]}"; do
    # map crate name -> binary name for the check
    case "$tool" in
        git-delta) bin=delta ;;
        fd-find)   bin=fd ;;
        ripgrep)   bin=rg ;;
        bob-nvim)  bin=bob ;;
        *)         bin=$tool ;;
    esac
    if ! have "$bin"; then
        echo "  cargo install $tool"
        cargo install "$tool"
    fi
done

# ---- Neovim (via bob) ----
if ! have nvim; then
    echo "--- nvim (via bob) ---"
    bob use stable
fi

# ---- fzf (git install, not apt — gives keybindings + shell integration) ----
if [ ! -d "$HOME/.fzf" ]; then
    echo "--- fzf ---"
    git clone --depth 1 https://github.com/junegunn/fzf.git "$HOME/.fzf"
    "$HOME/.fzf/install" --all --no-bash --no-fish
fi

# ---- Starship prompt ----
if ! have starship; then
    echo "--- starship ---"
    curl -sS https://starship.rs/install.sh | sh -s -- -y
fi

# ---- mise (version manager: zig, elixir, node) ----
if ! have mise; then
    echo "--- mise ---"
    curl https://mise.run | sh
fi

# ---- uv (Python tooling) ----
if ! have uv; then
    echo "--- uv ---"
    curl -LsSf https://astral.sh/uv/install.sh | sh
fi

# ---- bun ----
if ! have bun; then
    echo "--- bun ---"
    curl -fsSL https://bun.sh/install | bash
fi

# ---- flyctl (Fly.io) ----
if ! have flyctl; then
    echo "--- flyctl ---"
    curl -L https://fly.io/install.sh | sh
fi

# ---- lazygit ----
if ! have lazygit; then
    echo "--- lazygit ---"
    LAZYGIT_VERSION=$(curl -s "https://api.github.com/repos/jesseduffield/lazygit/releases/latest" | jq -r '.tag_name' | sed 's/^v//')
    curl -Lo /tmp/lazygit.tar.gz "https://github.com/jesseduffield/lazygit/releases/download/v${LAZYGIT_VERSION}/lazygit_${LAZYGIT_VERSION}_Linux_x86_64.tar.gz"
    tar xf /tmp/lazygit.tar.gz -C /tmp lazygit
    sudo install /tmp/lazygit /usr/local/bin/lazygit
    rm /tmp/lazygit /tmp/lazygit.tar.gz
fi

# ---- act (GitHub Actions local runner) ----
if ! have act; then
    echo "--- act ---"
    mkdir -p "$HOME/act"
    curl -s https://raw.githubusercontent.com/nektos/act/master/install.sh | bash -s -- -b "$HOME/act"
fi

# ---- Oh My Zsh ----
if [ ! -d "$HOME/.oh-my-zsh" ]; then
    echo "--- oh-my-zsh ---"
    sh -c "$(curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh)" "" --unattended
fi

# zsh plugins
ZSH_CUSTOM="${ZSH_CUSTOM:-$HOME/.oh-my-zsh/custom}"
[ -d "$ZSH_CUSTOM/plugins/zsh-autosuggestions" ] || \
    git clone https://github.com/zsh-autosuggestions/zsh-autosuggestions "$ZSH_CUSTOM/plugins/zsh-autosuggestions"
[ -d "$ZSH_CUSTOM/plugins/zsh-syntax-highlighting" ] || \
    git clone https://github.com/zsh-users/zsh-syntax-highlighting "$ZSH_CUSTOM/plugins/zsh-syntax-highlighting"

# ---- TPM (tmux plugin manager) ----
if [ ! -d "$HOME/.tmux/plugins/tpm" ]; then
    echo "--- tpm ---"
    git clone https://github.com/tmux-plugins/tpm "$HOME/.tmux/plugins/tpm"
fi

# ---- Skill symlinks ----
echo "--- skill symlinks ---"
for tool_dir in "$HOME/.claude/skills" "$HOME/.codex/skills"; do
    mkdir -p "$tool_dir"
    for skill in "$HOME/.config/skills"/*/; do
        name=$(basename "$skill")
        target="$tool_dir/$name"
        if [ ! -e "$target" ]; then
            ln -s "$HOME/.config/skills/$name" "$target"
            echo "  linked $name → $tool_dir"
        fi
    done
done

# ---- Default shell ----
if [ "$SHELL" != "$(which zsh)" ]; then
    echo "--- default shell → zsh ---"
    chsh -s "$(which zsh)" || echo "  (run manually: chsh -s \$(which zsh))"
fi

# ---- Decrypt secrets ----
if have yadm && [ -f "$HOME/.config/yadm/encrypt" ]; then
    echo "--- secrets ---"
    yadm decrypt || echo "  (run manually: yadm decrypt)"
fi

echo
echo "=== bootstrap complete ==="
echo "Restart your shell or run: exec zsh"
